# Masumi Payment Node (Preprod) — deploy separately
# Guide: README.md in this folder
# Mizizi instance: https://masumi-payment-service-production-7ec9.up.railway.app/

NETWORK=Preprod
BLOCKFROST_API_KEY_PREPROD=preprod_your_key_here
ADMIN_KEY=your-admin-key-min-15-chars
DATABASE_URL=postgresql://...

PURCHASE_WALLET_PREPROD_MNEMONIC=word1 word2 ... word24
SELLING_WALLET_PREPROD_MNEMONIC=word1 word2 ... word24
COLLECTION_WALLET_PREPROD_ADDRESS=addr_test1...

AUTO_WITHDRAW_PAYMENTS=true
AUTO_WITHDRAW_REFUNDS=true
