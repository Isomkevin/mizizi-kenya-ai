# Copy these lines into your root `.env` for Neo4j Aura (Option C).
# Replace URI and password with values from the Aura console.

NEO4J_PROFILE=aura
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-generated-password
NEO4J_DATABASE=neo4j
# Set to true on Aura Pro if you want cooperative trust PageRank during seed/setup
NEO4J_GDS=false
