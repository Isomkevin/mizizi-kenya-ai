# Mizizi app
MIZIZI_TENANT_ID=lesom-sandbox
MIZIZI_USE_LOCAL_STORE=true

# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Neo4j
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# After configuring Neo4j: run scripts/neo4j/001_constraints.cypher, then `bun run seed`
# Optional GDS (Aura Pro): scripts/neo4j/002_gds_optional.cypher

# AI providers
OPENAI_API_KEY=
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
