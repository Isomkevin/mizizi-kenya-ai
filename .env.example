# Mizizi app
MIZIZI_TENANT_ID=lesom-sandbox
MIZIZI_USE_LOCAL_STORE=true

# Lovable / public demo — skip Supabase auth and use officer dev session
VITE_MIZIZI_DEMO=true

# Supabase (leave empty for Lovable demo)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Neo4j — see docs/neo4j.md and copy ONE profile into .env:
#   Local Docker: .env.neo4j.local.example  →  bun run neo4j:local
#   Aura online:  .env.neo4j.aura.example   →  bun run neo4j:setup && bun run seed
NEO4J_PROFILE=
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_GDS=false

# AI providers
OPENAI_API_KEY=
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

# Masumi agentic data collection — see docs/masumi.md
MASUMI_MODE=demo
MASUMI_AGENTS_URL=http://localhost:8088
MASUMI_CALLBACK_SECRET=mizizi-dev-callback-secret
# MASUMI_PAYMENT_URL=http://localhost:3001/api/v1
# MASUMI_PAYMENT_API_KEY=
