{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "seed": "bun run scripts/seed/index.ts",
    "seed:node": "node --import tsx/esm scripts/seed/index.ts",
    "neo4j:up": "docker compose -f docker-compose.neo4j.yml up -d",
    "neo4j:down": "docker compose -f docker-compose.neo4j.yml down",
    "neo4j:logs": "docker compose -f docker-compose.neo4j.yml logs -f",
    "neo4j:wait": "bun run scripts/neo4j/wait-docker.ts",
    "neo4j:env:local": "bun run scripts/neo4j/apply-env.ts local",
    "neo4j:env:aura": "bun run scripts/neo4j/apply-env.ts aura",
    "neo4j:setup": "bun run scripts/neo4j/setup.ts",
    "neo4j:verify": "bun run scripts/neo4j/verify.ts",
    "neo4j:local": "bun run neo4j:env:local && bun run neo4j:up && bun run neo4j:wait && bun run neo4j:setup && bun run seed",
    "neo4j:aura": "bun run neo4j:setup && bun run seed",
    "masumi:env": "bun run deploy/masumi/scripts/apply-env.ts",
    "masumi:up": "docker compose -f deploy/masumi/docker-compose.yml up -d --build",
    "masumi:down": "docker compose -f deploy/masumi/docker-compose.yml down",
    "masumi:logs": "docker compose -f deploy/masumi/docker-compose.yml logs -f",
    "masumi:wait": "bun run deploy/masumi/scripts/wait-agents.ts",
    "masumi:local": "bun run masumi:env && bun run masumi:up && bun run masumi:wait",
    "zk:setup": "bash zk/scripts/setup.sh",
    "zk:prove": "bun run zk/scripts/prove.ts",
    "zk:verify": "bun run zk/scripts/verify-local.ts",
    "zk:test-vectors": "bun run zk/scripts/test-vectors.ts",
    "zk:deploy": "bun run contracts/credit_rails/scripts/deploy.ts",
    "zk:invoke-issue": "bun run contracts/credit_rails/scripts/invoke-issue.ts",
    "zk:invoke-drawdown": "bun run contracts/credit_rails/scripts/invoke-drawdown.ts",
    "format": "prettier --write ."
  },
