{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MiziziCreditTierWitness",
  "type": "object",
  "required": [
    "farmerId",
    "phone",
    "salt",
    "repaymentsOnTime",
    "monthlyInflowKes",
    "minScore",
    "minTier"
  ],
  "properties": {
    "farmerId": { "type": "string" },
    "phone": { "type": "string" },
    "salt": { "type": "string" },
    "repaymentsOnTime": {
      "type": "array",
      "items": { "type": "integer", "enum": [0, 1] },
      "minItems": 6,
      "maxItems": 6
    },
    "monthlyInflowKes": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 },
      "minItems": 6,
      "maxItems": 6
    },
    "minScore": { "type": "integer", "default": 60 },
    "minTier": { "type": "integer", "default": 2 },
    "tier": { "type": "integer", "minimum": 1, "maximum": 4 },
    "rawScore": { "type": "integer", "minimum": 0, "maximum": 100 }
  }
}
